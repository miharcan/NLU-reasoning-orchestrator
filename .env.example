# Core runtime
ADJUDICATOR_MODE=mock
ADJUDICATOR_HTTP_URL=
ADJUDICATOR_HTTP_TIMEOUT_SECONDS=12
ADJUDICATOR_HTTP_COOLDOWN_SECONDS=180

# Security
API_AUTH_ENABLED=false
API_KEYS=demo-key-1,demo-key-2
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# State
STATE_BACKEND=in_memory
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_KEY_PREFIX=dialogue
REDIS_STATE_TTL_SECONDS=86400

# SLO targets
SLO_P95_LATENCY_MS=1500
SLO_FALLBACK_RATE=0.15
SLO_POLICY_DENIAL_RATE=0.05
SLO_JSON_VALIDITY_RATE=0.999
